{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": [
    "src/index.ts",
    "src/cli/**/*",
    "src/controllers/**/*",
    "src/engines/**/*",
    "src/types/**/*"
  ]
}
